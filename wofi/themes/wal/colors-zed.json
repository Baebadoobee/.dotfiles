{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0f101690",
                "editor.background": "#0f101690",
                "editor.foreground": "#c3c3c4",
                "text": "#c3c3c4",
                "text.muted": "#c3c3c470",
                "text.ignored": "#c3c3c440",
                "text.placeholder": "#c3c3c450",
                "ignored": "#c3c3c430",
                "element.hover": "#c3c3c430",
                "ghost_element.hover": "#5C7BB930",
                "ghost_element.selected": "#5C7BB930",
                "ghost_element.active": "#5C7BB960",
                "border": "#0f1016",
                "editor.highlighted_line.background": "#5C7BB910",
                "editor.active_line.background": "#5C7BB910",
                "panel.background": "#0f101690",
                "title_bar.background": "#0f101690",
                "title_bar.inactive_background": "#0f101690",
                "status_bar.background": "#0f101690",
                "drop_target.background": "#0f101690",
                "elevated_surface.background": "#0f1016",
                "toolbar.background": "#0f101690",
                "tab_bar.background": "#0f101690",
                "tab.inactive_background": "#0f101690",
                "tab.active_background": "#5C7BB930",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0f1016",
                "scrollbar.thumb.background": "#5C7BB9",
                "editor.gutter.background": "#0f101690",
                "terminal.background": "#0f101610",
                "terminal.foreground": "#c3c3c4",
                "terminal.dim_foreground": "#c3c3c4",
                "terminal.bright_foreground": "#c3c3c4",
                "terminal.ansi.black": "#0f1016",
                "terminal.ansi.red": "#5C7BB9",
                "terminal.ansi.green": "#A46C99",
                "terminal.ansi.yellow": "#D9769B",
                "terminal.ansi.blue": "#EB7797",
                "terminal.ansi.magenta": "#CF7AA9",
                "terminal.ansi.cyan": "#A77DC2",
                "terminal.ansi.white": "#c3c3c4",
                "terminal.ansi.bright_black": "#5a5a6f",
                "terminal.ansi.bright_red": "#5C7BB9",
                "terminal.ansi.bright_green": "#A46C99",
                "terminal.ansi.bright_yellow": "#D9769B",
                "terminal.ansi.bright_blue": "#EB7797",
                "terminal.ansi.bright_magenta": "#CF7AA9",
                "terminal.ansi.bright_cyan": "#A77DC2",
                "terminal.ansi.bright_white": "#c3c3c4",
                "modified": "#5C7BB9",
                "syntax": {
                    "attribute": {
                        "color": "#5C7BB9"
                    },
                    "boolean": {
                      "color": "#A46C99"
                    },
                    "comment": {
                      "color": "#5a5a6f"
                    },
                    "comment.doc": {
                      "color": "#5a5a6f"
                    },
                    "constant": {
                      "color": "#A46C99"
                    },
                    "function": {
                      "color": "#A77DC2"
                    },
                    "keyword": {
                      "color": "#EB7797"
                    },
                    "number": {
                      "color": "#CF7AA9"
                    },
                    "operator": {
                      "color": "#EB7797"
                    },
                    "string": {
                      "color": "#5C7BB9"
                    },
                    "variable": {
                      "color": "#A46C99"
                    }
                },
                "players": [
                  {
                    "cursor": "#5C7BB9",
                    "background": "#0f1016",
                    "selection": "#5C7BB930"
                  }
                ]
            }
        }
    ]
}
