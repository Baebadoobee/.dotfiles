{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#12111b90",
                "editor.background": "#12111b90",
                "editor.foreground": "#c3c3c6",
                "text": "#c3c3c6",
                "text.muted": "#c3c3c670",
                "text.ignored": "#c3c3c640",
                "text.placeholder": "#c3c3c650",
                "ignored": "#c3c3c630",
                "element.hover": "#c3c3c630",
                "ghost_element.hover": "#63627C30",
                "ghost_element.selected": "#63627C30",
                "ghost_element.active": "#63627C60",
                "border": "#12111b",
                "editor.highlighted_line.background": "#63627C10",
                "editor.active_line.background": "#63627C10",
                "panel.background": "#12111b90",
                "title_bar.background": "#12111b90",
                "title_bar.inactive_background": "#12111b90",
                "status_bar.background": "#12111b90",
                "drop_target.background": "#12111b90",
                "elevated_surface.background": "#12111b",
                "toolbar.background": "#12111b90",
                "tab_bar.background": "#12111b90",
                "tab.inactive_background": "#12111b90",
                "tab.active_background": "#63627C30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#12111b",
                "scrollbar.thumb.background": "#63627C",
                "editor.gutter.background": "#12111b90",
                "terminal.background": "#12111b10",
                "terminal.foreground": "#c3c3c6",
                "terminal.dim_foreground": "#c3c3c6",
                "terminal.bright_foreground": "#c3c3c6",
                "terminal.ansi.black": "#12111b",
                "terminal.ansi.red": "#63627C",
                "terminal.ansi.green": "#586C87",
                "terminal.ansi.yellow": "#6B6A84",
                "terminal.ansi.blue": "#BC7592",
                "terminal.ansi.magenta": "#7D84A0",
                "terminal.ansi.cyan": "#D99C9B",
                "terminal.ansi.white": "#c3c3c6",
                "terminal.ansi.bright_black": "#5c5c71",
                "terminal.ansi.bright_red": "#63627C",
                "terminal.ansi.bright_green": "#586C87",
                "terminal.ansi.bright_yellow": "#6B6A84",
                "terminal.ansi.bright_blue": "#BC7592",
                "terminal.ansi.bright_magenta": "#7D84A0",
                "terminal.ansi.bright_cyan": "#D99C9B",
                "terminal.ansi.bright_white": "#c3c3c6",
                "modified": "#63627C",
                "syntax": {
                    "attribute": {
                        "color": "#63627C"
                    },
                    "boolean": {
                      "color": "#586C87"
                    },
                    "comment": {
                      "color": "#5c5c71"
                    },
                    "comment.doc": {
                      "color": "#5c5c71"
                    },
                    "constant": {
                      "color": "#586C87"
                    },
                    "function": {
                      "color": "#D99C9B"
                    },
                    "keyword": {
                      "color": "#BC7592"
                    },
                    "number": {
                      "color": "#7D84A0"
                    },
                    "operator": {
                      "color": "#BC7592"
                    },
                    "string": {
                      "color": "#63627C"
                    },
                    "variable": {
                      "color": "#586C87"
                    }
                },
                "players": [
                  {
                    "cursor": "#63627C",
                    "background": "#12111b",
                    "selection": "#63627C30"
                  }
                ]
            }
        }
    ]
}
