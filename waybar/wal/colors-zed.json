{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#76172790",
                "editor.background": "#76172790",
                "editor.foreground": "#dcc5c9",
                "text": "#dcc5c9",
                "text.muted": "#dcc5c970",
                "text.ignored": "#dcc5c940",
                "text.placeholder": "#dcc5c950",
                "ignored": "#dcc5c930",
                "element.hover": "#dcc5c930",
                "ghost_element.hover": "#6972F230",
                "ghost_element.selected": "#6972F230",
                "ghost_element.active": "#6972F260",
                "border": "#761727",
                "editor.highlighted_line.background": "#6972F210",
                "editor.active_line.background": "#6972F210",
                "panel.background": "#76172790",
                "title_bar.background": "#76172790",
                "title_bar.inactive_background": "#76172790",
                "status_bar.background": "#76172790",
                "drop_target.background": "#76172790",
                "elevated_surface.background": "#761727",
                "toolbar.background": "#76172790",
                "tab_bar.background": "#76172790",
                "tab.inactive_background": "#76172790",
                "tab.active_background": "#6972F230",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#761727",
                "scrollbar.thumb.background": "#6972F2",
                "editor.gutter.background": "#76172790",
                "terminal.background": "#76172710",
                "terminal.foreground": "#dcc5c9",
                "terminal.dim_foreground": "#dcc5c9",
                "terminal.bright_foreground": "#dcc5c9",
                "terminal.ansi.black": "#761727",
                "terminal.ansi.red": "#6972F2",
                "terminal.ansi.green": "#D651C1",
                "terminal.ansi.yellow": "#E5A5A3",
                "terminal.ansi.blue": "#DEC5B4",
                "terminal.ansi.magenta": "#E2C5B5",
                "terminal.ansi.cyan": "#9F9CE6",
                "terminal.ansi.white": "#dcc5c9",
                "terminal.ansi.bright_black": "#927a7e",
                "terminal.ansi.bright_red": "#6972F2",
                "terminal.ansi.bright_green": "#D651C1",
                "terminal.ansi.bright_yellow": "#E5A5A3",
                "terminal.ansi.bright_blue": "#DEC5B4",
                "terminal.ansi.bright_magenta": "#E2C5B5",
                "terminal.ansi.bright_cyan": "#9F9CE6",
                "terminal.ansi.bright_white": "#dcc5c9",
                "modified": "#6972F2",
                "syntax": {
                    "attribute": {
                        "color": "#6972F2"
                    },
                    "boolean": {
                      "color": "#D651C1"
                    },
                    "comment": {
                      "color": "#927a7e"
                    },
                    "comment.doc": {
                      "color": "#927a7e"
                    },
                    "constant": {
                      "color": "#D651C1"
                    },
                    "function": {
                      "color": "#9F9CE6"
                    },
                    "keyword": {
                      "color": "#DEC5B4"
                    },
                    "number": {
                      "color": "#E2C5B5"
                    },
                    "operator": {
                      "color": "#DEC5B4"
                    },
                    "string": {
                      "color": "#6972F2"
                    },
                    "variable": {
                      "color": "#D651C1"
                    }
                },
                "players": [
                  {
                    "cursor": "#6972F2",
                    "background": "#761727",
                    "selection": "#6972F230"
                  }
                ]
            }
        }
    ]
}
